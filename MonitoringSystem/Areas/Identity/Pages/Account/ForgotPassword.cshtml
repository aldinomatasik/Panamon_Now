@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_AuthLayout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-lg border-0" style="background: transparent;">
                <div class="text-center py-4">
                    <h2 class="text-white">@ViewData["Title"]</h2>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="mb-3">
                            <input asp-for="Input.Email" 
                                   class="custom-input" 
                                   placeholder="Email" 
                                   aria-required="true" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <input asp-for="Input.NewPassword" 
                                   type="password"
                                   class="custom-input" 
                                   placeholder="New Password" 
                                   aria-required="true" />
                            <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <input asp-for="Input.ConfirmPassword" 
                                   type="password"
                                   class="custom-input" 
                                   placeholder="Confirm Password" 
                                   aria-required="true" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-primary btn-lg">Reset Password</button>
                        </div>

                        <div class="text-center">
                            <span class="text-white-50">Already have an account?</span>
                            <a asp-page="./Login" class="text-decoration-none text-white fw-bold"> Log in</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}