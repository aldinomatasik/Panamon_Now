@page
@using System.Globalization;
@{
    ViewData["Title"] = "Machine";
}

<link rel="stylesheet" href="~/css/Machine.css" asp-append-version="true" />

<div id="machineContainer">
    <div class="container-fluid">

        <!-- FILTER AREA -->
        <div class="filter-area-with-lines">
            <div class="panamon-bottom-line"></div>
            <div class="panamon-bottomm-line"></div>

            <div class="filter-content">
                <div class="d-flex flex-wrap align-items-center gap-3">

                    <div class="d-flex align-items-center gap-2">
                        <label class="mb-0 text-white small">Start Date</label>
                        <div class="date-input-wrapper">
                            <input type="text" id="filterStartDate" class="datepicker"
                                   placeholder="yyyy-mm-dd" autocomplete="off" />
                            <i class="fa-solid fa-calendar-days date-icon" id="iconStartDate"></i>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <label class="mb-0 text-white small">End Date</label>
                        <div class="date-input-wrapper">
                            <input type="text" id="filterEndDate" class="datepicker"
                                   placeholder="yyyy-mm-dd" autocomplete="off" />
                            <i class="fa-solid fa-calendar-days date-icon" id="iconEndDate"></i>
                        </div>
                    </div>

                    <button type="button" id="btnSearch" class="btn btn-sm btn-primary">Search</button>

                    <button type="button" class="btn btn-sm btn-success"
                            data-bs-toggle="modal" data-bs-target="#uploadModalMachine">
                        <i class="fas fa-file-excel me-2"></i>Upload Machine Efficiency
                    </button>

                </div>
            </div>
        </div>

        <!-- ROW: DENAH KIRI + TABEL KANAN -->
        <div class="machine-layout-row">

            <!-- DENAH PABRIK -->
            <div class="factory-map-wrapper">
                <img src="~/assets/denah_pabrik.png" alt="Factory Floor Plan" class="factory-map-img" />

                <svg id="line-overlay">
                    <defs>
                        <marker id="arrowhead" markerWidth="10" markerHeight="7"
                                refX="0" refY="3.5" orient="auto">
                            <polygon points="0 0, 10 3.5, 0 7" fill="rgba(255,255,255,0.6)" />
                        </marker>
                    </defs>
                </svg>

                <div class="info-balloon" id="machine-300t-new"><span class="balloon-title">300TN</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-300t"><span class="balloon-title">300T</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-200t"><span class="balloon-title">200T</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-400t"><span class="balloon-title">400T</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-110t-amada"><span class="balloon-title">110T Amada</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-110t-komatsu"><span class="balloon-title">110T Komatsu</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-sf-250"><span class="balloon-title">SF 250</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-fix-80"><span class="balloon-title">FIX 80</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-fix-12"><span class="balloon-title">FIX 12</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-fix-36"><span class="balloon-title">FIX 36</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-kyoshin-ori"><span class="balloon-title">Kyoshin</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-kyoshin"><span class="balloon-title">6.35</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-li-chin"><span class="balloon-title">Li-chin</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-14-row"><span class="balloon-title">14 Row</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="machine-7-row"><span class="balloon-title">7 Row</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="oven"><span class="balloon-title">Oven</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="evap"><span class="balloon-title">Evap</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="cond"><span class="balloon-title">Cond</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="outdoor-unit-marker"><span class="balloon-title">Outdoor Unit Assembly</span><div class="balloon-details"></div></div>
                <div class="info-balloon" id="indoor-unit-marker"><span class="balloon-title">Indoor Unit Assembly</span><div class="balloon-details"></div></div>
            </div>

            <!-- TABEL KANAN -->
            <div class="machine-table-wrapper">
                <div class="machine-table-box">
                    <div class="machine-table-header">
                        <span class="machine-table-title">Machine Efficiency</span>
                    </div>
                    <div class="machine-table-scroll">
                        <table class="machine-eff-table">
                            <thead>
                                <tr>
                                    <th>Machine Name</th>
                                    <th>OEE</th>
                                    <th>Operating Ratio</th>
                                    <th>Ability</th>
                                    <th>Quality</th>
                                </tr>
                            </thead>
                            <tbody id="machineEffTableBody">
                                <tr><td colspan="5" class="no-data">No data available</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- ===================== MODAL UPLOAD MACHINE EFFICIENCY ===================== -->
<div class="modal fade" id="uploadModalMachine" tabindex="-1" aria-labelledby="uploadModalMachineLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="uploadModalMachineLabel">
                    <i class="fas fa-file-upload me-2"></i> Upload Machine Efficiency Data
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <!-- Alert sukses/gagal -->
                <div id="uploadAlertMachine" class="alert d-none"></div>

                <!-- 1. Pilih File Excel -->
                <div class="mb-3">
                    <label class="form-label fw-bold">1. Choose Excel File</label>
                    <input type="file" id="machineExcelFile" class="form-control" accept=".xlsx" required />
                </div>

                <!-- 2. Pilih Target Machine dari dropdown -->
                <div class="mb-3">
                    <label class="form-label fw-bold">2. Select Target Machine</label>
                    <select id="selectUploadMachine" class="form-select" required>
                        <option value="" disabled selected>Loading machines...</option>
                    </select>
                    <div class="form-text text-muted">Pilih machine yang sesuai dengan data Excel ini.</div>
                </div>

                <hr />

                <!-- 3. Pilih Bulan & Tahun -->
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">3. Untuk Bulan:</label>
                        <select id="machineTargetMonth" class="form-select" required>
                            @for (int i = 1; i <= 12; i++)
                            {
                                        <option value="@i" selected="@(i == DateTime.Now.Month ? "selected" : null)">
                                    @CultureInfo.GetCultureInfo("en-US").DateTimeFormat.GetMonthName(i)
                                        </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Untuk Tahun:</label>
                        <select id="machineTargetYear" class="form-select" required>
                            @for (int i = DateTime.Now.Year - 3; i <= DateTime.Now.Year + 5; i++)
                            {
                                        <option value="@i" selected="@(i == DateTime.Now.Year ? "selected" : null)">@i</option>
                            }
                        </select>
                    </div>
                </div>

                <!-- ✅ TAMBAHAN: Download Template -->
                <hr />
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small text-muted">Need the format?</span>
                    <a href="/api/machine/download-template" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-download me-1"></i> Download Template
                    </a>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" id="btnImportMachine" class="btn btn-success">
                    <i class="fas fa-upload me-1"></i> Import Data
                </button>
            </div>
        </div>
    </div>
</div>
<!-- ===================== END MODAL ===================== -->

@section Scripts {
            <script>
                const today = new Date();
                const todayStr = today.getFullYear() + '-'
                    + String(today.getMonth() + 1).padStart(2, '0') + '-'
                    + String(today.getDate()).padStart(2, '0');

                function applyFlatpickrTheme(calendarEl) {
                    const isLight = document.body.classList.contains('light-mode');
                    calendarEl.classList.remove('theme-light', 'theme-dark');
                    calendarEl.classList.add(isLight ? 'theme-light' : 'theme-dark');
                }

                const startPicker = flatpickr('#filterStartDate', {
                    dateFormat: 'Y-m-d', defaultDate: todayStr, allowInput: true, disableMobile: true,
                    onReady: (_, __, instance) => applyFlatpickrTheme(instance.calendarContainer),
                    onChange: (dates) => { if (dates[0]) endPicker.set('minDate', dates[0]); }
                });

                const endPicker = flatpickr('#filterEndDate', {
                    dateFormat: 'Y-m-d', defaultDate: todayStr, allowInput: true, disableMobile: true,
                    onReady: (_, __, instance) => applyFlatpickrTheme(instance.calendarContainer),
                    onChange: (dates) => {
                        if (dates[0]) document.getElementById('filterStartDate')._flatpickr.set('maxDate', dates[0]);
                    }
                });

                const themeObserver = new MutationObserver(() => {
                    document.querySelectorAll('.flatpickr-calendar').forEach(cal => applyFlatpickrTheme(cal));
                });
                themeObserver.observe(document.body, { attributes: true, attributeFilter: ['class'] });

                document.getElementById('iconStartDate').addEventListener('click', () =>
                    document.getElementById('filterStartDate')._flatpickr.open());
                document.getElementById('iconEndDate').addEventListener('click', () =>
                    document.getElementById('filterEndDate')._flatpickr.open());

                async function loadMachineDropdown() {
                    const select = document.getElementById('selectUploadMachine');
                    try {
                        const res = await fetch('/api/machine/list', {
                            headers: { 'Accept': 'application/json' }
                        });
                        if (!res.ok) throw new Error('Gagal load data mesin');
                        const machines = await res.json();

                        if (!machines || machines.length === 0) {
                            select.innerHTML = '<option value="" disabled selected>Tidak ada data mesin</option>';
                            return;
                        }

                        select.innerHTML = '<option value="" disabled selected>-- Pilih Machine --</option>'
                            + machines.map(m => `<option value="${m.machineName}">${m.machineName}</option>`).join('');

                    } catch (err) {
                        console.error('Error load machine list:', err);
                        select.innerHTML = '<option value="" disabled selected>Gagal load data mesin</option>';
                    }
                }

                document.getElementById('uploadModalMachine').addEventListener('show.bs.modal', () => {
                    loadMachineDropdown();
                });

                document.getElementById('uploadModalMachine').addEventListener('hidden.bs.modal', () => {
                    document.getElementById('uploadAlertMachine').className = 'alert d-none';
                    document.getElementById('machineExcelFile').value = '';
                    document.getElementById('selectUploadMachine').innerHTML = '<option value="" disabled selected>Loading machines...</option>';
                });

                document.getElementById('btnImportMachine').addEventListener('click', async function () {
                    const file        = document.getElementById('machineExcelFile').files[0];
                    const machineName = document.getElementById('selectUploadMachine').value;
                    const month       = document.getElementById('machineTargetMonth').value;
                    const year        = document.getElementById('machineTargetYear').value;
                    const alertBox    = document.getElementById('uploadAlertMachine');

                    if (!file) {
                        alertBox.className = 'alert alert-warning';
                        alertBox.textContent = 'Harap pilih file Excel terlebih dahulu.';
                        alertBox.classList.remove('d-none');
                        return;
                    }
                    if (!machineName) {
                        alertBox.className = 'alert alert-warning';
                        alertBox.textContent = 'Harap pilih machine terlebih dahulu.';
                        alertBox.classList.remove('d-none');
                        return;
                    }

                    this.disabled = true;
                    this.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Importing...';
                    alertBox.className = 'alert d-none';

                    try {
                        const formData = new FormData();
                        formData.append('file',        file);
                        formData.append('machineName', machineName);
                        formData.append('month',       month);
                        formData.append('year',        year);

                        const res = await fetch('/api/machine/import', {
                            method: 'POST',
                            body: formData
                        });

                        const result = await res.json();

                        if (res.ok && result.success) {
                            alertBox.className = 'alert alert-success';
                            alertBox.textContent = result.message;
                            alertBox.classList.remove('d-none');
                            document.getElementById('machineExcelFile').value = '';
                            setTimeout(() => {
                                loadMachineData();
                                bootstrap.Modal.getInstance(
                                    document.getElementById('uploadModalMachine')
                                ).hide();
                            }, 1500);
                        } else {
                            alertBox.className = 'alert alert-danger';
                            alertBox.textContent = result.error || 'Import gagal, coba lagi.';
                            alertBox.classList.remove('d-none');
                        }

                    } catch (err) {
                        alertBox.className = 'alert alert-danger';
                        alertBox.textContent = 'Sistem error: ' + err.message;
                        alertBox.classList.remove('d-none');
                    } finally {
                        this.disabled = false;
                        this.innerHTML = '<i class="fas fa-upload me-1"></i> Import Data';
                    }
                });

                async function loadMachineData() {
                    const tbody     = document.getElementById('machineEffTableBody');
                    const startDate = document.getElementById('filterStartDate').value;
                    const endDate   = document.getElementById('filterEndDate').value;

                    tbody.innerHTML = '<tr><td colspan="5" class="no-data">Loading...</td></tr>';

                    if (!startDate || !endDate) {
                        tbody.innerHTML = '<tr><td colspan="5" class="no-data" style="color:orange;">Harap isi Start Date dan End Date.</td></tr>';
                        return;
                    }
                    if (startDate > endDate) {
                        tbody.innerHTML = '<tr><td colspan="5" class="no-data" style="color:orange;">Start Date tidak boleh lebih besar dari End Date.</td></tr>';
                        return;
                    }

                    try {
                        const response = await fetch(
                            `/api/machine/efficiency?startDate=${encodeURIComponent(startDate)}&endDate=${encodeURIComponent(endDate)}`,
                            { headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' } }
                        );

                        if (!response.ok) throw new Error(`Server error: ${response.status}`);

                        const contentType = response.headers.get("content-type");
                        if (!contentType || !contentType.includes("application/json"))
                            throw new Error("Server tidak mengirim JSON.");

                        const data = await response.json();

                        if (data.error) {
                            tbody.innerHTML = `<tr><td colspan="5" class="no-data" style="color:red;">Error: ${data.error}</td></tr>`;
                            return;
                        }
                        if (!data || data.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="5" class="no-data">No data available</td></tr>';
                            return;
                        }

                        tbody.innerHTML = data.map(m => `
            <tr>
                <td class="td-machine-name">${m.machineName}</td>
                <td>${m.oEE !== '-' ? m.oEE + '%' : '-'}</td>
                <td>${m.operatingRatio !== '-' ? m.operatingRatio : '-'}</td>
                <td>${m.ability !== '-' ? m.ability : '-'}</td>
                <td>${m.quality !== '-' ? m.quality : '-'}</td>
            </tr>
        `).join('');

                    } catch (err) {
                        console.error("Fetch Error:", err);
                        tbody.innerHTML = `<tr><td colspan="5" class="no-data" style="color:red;">Sistem Error: ${err.message}</td></tr>`;
                    }
                }

                function drawConnectorLines() {
                    const container = document.querySelector('.factory-map-wrapper');
                    const svg = document.getElementById('line-overlay');
                    svg.innerHTML = svg.querySelector('defs').outerHTML;

                    const machineCoordinates = {
                        'outdoor-unit-marker':  { x: 23, y: 37 },
                        'indoor-unit-marker':   { x: 11, y: 53 },
                        'machine-300t-new':     { x: 87, y: 73 },
                        'machine-300t':         { x: 86, y: 52 },
                        'machine-200t':         { x: 84, y: 44 },
                        'machine-400t':         { x: 88, y: 64 },
                        'machine-110t-amada':   { x: 80, y: 32 },
                        'machine-110t-komatsu': { x: 88, y: 32 },
                        'machine-sf-250':       { x: 68, y: 20 },
                        'machine-fix-80':       { x: 62, y: 20 },
                        'machine-fix-12':       { x: 57, y: 20 },
                        'machine-fix-36':       { x: 50, y: 20 },
                        'machine-kyoshin-ori':  { x: 51, y: 36 },
                        'machine-kyoshin':      { x: 63, y: 36 },
                        'machine-li-chin':      { x: 57, y: 36 },
                        'machine-14-row':       { x: 83, y: 19 },
                        'machine-7-row':        { x: 86, y: 22 },
                        'oven':                 { x: 69, y: 47 },
                        'evap':                 { x: 63, y: 65 },
                        'cond':                 { x: 73, y: 65 }
                    };

                    const cw = container.offsetWidth;
                    const ch = container.offsetHeight;

                    for (const balloonId in machineCoordinates) {
                        const balloon = document.getElementById(balloonId);
                        if (!balloon) continue;

                        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
                        const sx = balloon.offsetLeft + balloon.offsetWidth / 2;
                        const sy = balloon.classList.contains('tacked-from-top')
                            ? balloon.offsetTop : balloon.offsetTop + balloon.offsetHeight;
                        const ex = (machineCoordinates[balloonId].x / 100) * cw;
                        const ey = (machineCoordinates[balloonId].y / 100) * ch;

                        line.setAttribute('x1', sx); line.setAttribute('y1', sy);
                        line.setAttribute('x2', ex); line.setAttribute('y2', ey);
                        line.setAttribute('class', 'connector-line');
                        svg.appendChild(line);
                    }
                }

                document.addEventListener('DOMContentLoaded', () => {
                    drawConnectorLines();
                    window.addEventListener('resize', drawConnectorLines);
                    loadMachineData();
                });

                document.getElementById('btnSearch').addEventListener('click', () => loadMachineData());
            </script>
}
